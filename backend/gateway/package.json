    "helmet": "^7.1.0",
    "http-proxy-middleware": "^2.0.6",
    "morgan": "^1.10.0",
    "swagger-ui-express": "^4.6.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
